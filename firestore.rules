rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    // ── Servizi (public read for published, admin-only via Admin SDK) ────────

    match /servizi/{servizioId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if false; // all writes go through server actions / Admin SDK
    }

    // ── Categorie (placeholder — public read) ────────────────────────────────

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Users (only own profile; admin can read all) ─────────────────────────

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false; // creation goes through /api/auth/register

      match /addresses/{addressId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if false;
      }
    }

    // ── Ordini (owner reads own, admin reads all; writes only via webhook) ───

    match /ordini/{ordineId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false; // Stripe webhook writes via Admin SDK
    }

    // ── Conversazioni e messaggi (real-time chat) ────────────────────────────
    // Conversation docs are keyed BY userId, so we can check the path
    // directly instead of doing an extra get() on resource.data.userId.

    match /conversations/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // server actions handle writes with validation

      match /messages/{messageId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }
    }

    // ── Settings (public read for shop config) ───────────────────────────────

    match /settings/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Deny everything else by default ──────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
